# Environment Variables Template
# 环境变量模板
# ⚠️ NEVER commit actual .env file to GitHub!

# SkillPay Billing API
SKILLPAY_API_URL=https://skillpay.me
SKILLPAY_API_KEY=your_api_key_here
SKILLPAY_SKILL_ID=your_skill_id_here

# GitHub Token (for local development)
# GITHUB_TOKEN=ghp_xxx

# Database
# DATABASE_URL=sqlite://./dev.db

# Other secrets
# API_SECRET=your_secret_here
